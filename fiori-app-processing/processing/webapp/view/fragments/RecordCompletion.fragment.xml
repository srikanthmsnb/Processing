					<!--</Select>-->
				</InputListItem>
				<InputListItem label="Smalls (lb)">
					<Input width="6rem" value="{jsonModel>/displayrecCompletionObj/2/smallQty}" type="Number" change="onChangeValue" placeholder="Enter Qty"/>
					<Input id="beggingTag3" width="16rem" submit="beggingTag3Scan" placeholder="Scan package tag" liveChange="validateTag"/>
