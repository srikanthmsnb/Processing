				<InputListItem label="B-Flower (lb)">
					<Input width="6rem" value="{jsonModel>/displayrecCompletionObj/1/BflowerQty}" type="Number" change="onChangeValue" placeholder="Enter Qty"/>
					<Input id="beggingTag2" width="16rem" submit="beggingTag2Scan" placeholder="Scan package tag" liveChange="validateTag"/>
