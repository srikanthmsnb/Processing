			</FlexBox>
		</content>
		<beginButton>
			<Button type="Emphasized" text="OK" press="confirmRecordCompletion" enabled="{= !${jsonModel>/busyView} }"/>
		</beginButton>
		<endButton>
			<Button type="Transparent" text="Cancel" press="recordCompletionCancel"></Button>
		</endButton>
	</Dialog>
</core:FragmentDefinition>